# REQUIRED: Postgres connection string (Neon/Render/etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# API server port
API_PORT=4000

# Set a strong random secret in production
AUTH_TOKEN_SECRET=replace-with-long-random-secret
AUTH_TOKEN_TTL_SECONDS=43200

# Optional: override default seeded passwords
SEED_ADMIN_PASSWORD=admin123
SEED_PRODUCTION_PASSWORD=production123
SEED_WAREHOUSE_PASSWORD=warehouse123
SEED_LOGISTICS_PASSWORD=logistics123
SEED_MANAGEMENT_PASSWORD=management123
