{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist",      // <-- compile JS goes here
    "noEmit": false         // <-- must emit JS
  },
  "include": ["server.ts", "prisma/**/*.ts"]
}